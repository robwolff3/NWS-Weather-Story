# ─────────────────────────────────────────────────────────────
# NWS Weather Story Monitor — configuration
# Copy to .env and fill in. Configure AT LEAST ONE notification channel.
# ─────────────────────────────────────────────────────────────

# Which NWS office (WFO) to watch. Find yours at https://www.weather.gov
# Examples: dtx=Detroit, okx=New York, lot=Chicago, fwd=Dallas/Fort Worth
WFO=dtx

# ── Email channel (Gmail SMTP) ───────────────────────────────
# Create an app password at https://myaccount.google.com/apppasswords
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your16charapppwd
# Comma-separated recipients. Defaults to GMAIL_USER if omitted.
NOTIFY_EMAILS=you@example.com,someone@example.com

# ── Apprise channel (Discord/Telegram/ntfy/Slack/...) ────────
# Comma-separated Apprise URLs. See https://github.com/caronc/apprise/wiki
# Examples:
#   discord://webhook_id/webhook_token
#   tgram://bot_token/chat_id
#   ntfy://ntfy.sh/your-topic
APPRISE_URLS=

# ── Optional ─────────────────────────────────────────────────
# CHECK_INTERVAL=3600
# SKIP_KEYWORDS=Marine
# Region scanned for SKIP_KEYWORDS as left,top,right,bottom (pixels or % of image).
# Defaults to the top band (full width x 80px). Example: scan the top 15%:
# OCR_REGION=0,0,100%,15%
# UPTIME_KUMA_PUSH_URL=https://uptime.example.com/api/push/abcd1234
# LOCATION_NAME=Detroit
# TIMEZONE=America/Detroit
# IMAGE_NAMES=Tab1FileL.png,Tab2FileL.png,Tab3FileL.png,Tab4FileL.png,Tab5FileL.png
# STORY_URL=https://www.weather.gov/dtx/weatherstory
# EXTRA_LINKS=NWS Forecast|https://forecast.weather.gov/MapClick.php?lat=42.15&lon=-83.49
